# NanoOS Kernel Wayland/Graphics Configuration Fragment
# Required for: Wayland compositors, EGL/GLES, GPU acceleration

# ── DRM/KMS Core ─────────────────────────────────────────────
CONFIG_DRM=y
CONFIG_DRM_KMS_HELPER=y
CONFIG_DRM_KMS_FB_HELPER=y
CONFIG_DRM_GEM_SHMEM_HELPER=y

# ── DMA-BUF (buffer sharing between GPU and Wayland) ─────────
CONFIG_DMA_SHARED_BUFFER=y
CONFIG_DMABUF_HEAPS=y
CONFIG_DMABUF_HEAPS_SYSTEM=y

# ── VirtIO GPU (QEMU) ────────────────────────────────────────
CONFIG_DRM_VIRTIO_GPU=y

# ── Framebuffer (fallback console) ────────────────────────────
CONFIG_FB=y
CONFIG_FB_ARMCLCD=y
CONFIG_FRAMEBUFFER_CONSOLE=y

# ── EGL/OpenGL support ───────────────────────────────────────
CONFIG_DRM_FBDEV_EMULATION=y

# ── Video4Linux (camera, later) ──────────────────────────────
CONFIG_MEDIA_SUPPORT=m
CONFIG_VIDEO_DEV=m
CONFIG_VIDEO_V4L2=m
CONFIG_VIDEOBUF2_CORE=m
CONFIG_VIDEOBUF2_VMALLOC=m

# ── Sound (ALSA core for PipeWire) ───────────────────────────
CONFIG_SOUND=y
CONFIG_SND=y
CONFIG_SND_TIMER=y
CONFIG_SND_PCM=y
CONFIG_SND_JACK=y
CONFIG_SND_DYNAMIC_MINORS=y
CONFIG_SND_PROC_FS=y
CONFIG_SND_HRTIMER=y
# VirtIO sound (QEMU)
CONFIG_SND_VIRTIO=y
# USB audio (for real hardware)
CONFIG_SND_USB_AUDIO=m
# SOC audio (for ARM boards)
CONFIG_SND_SOC=m

# ── Panfrost / Mali GPU (for real ARM hardware, future) ──────
CONFIG_DRM_PANFROST=m
CONFIG_DRM_LIMA=m

# ── Real hardware GPU options (for RPi, future) ──────────────
CONFIG_DRM_VC4=m
CONFIG_DRM_V3D=m
