# NanoOS Kernel Mobile Device Configuration Fragment
# Required for: touchscreen, backlight, battery, sensors, audio

# ── Touchscreen / Input ──────────────────────────────────────
CONFIG_INPUT_TOUCHSCREEN=y
CONFIG_INPUT_MISC=y
CONFIG_INPUT_UINPUT=y
CONFIG_INPUT_POLLDEV=y
# Multi-touch protocol support
CONFIG_INPUT_MT=y

# ── Backlight / Display ─────────────────────────────────────
CONFIG_BACKLIGHT_CLASS_DEVICE=y
CONFIG_BACKLIGHT_GENERIC=y
CONFIG_LCD_CLASS_DEVICE=y

# ── LEDs ─────────────────────────────────────────────────────
CONFIG_NEW_LEDS=y
CONFIG_LEDS_CLASS=y
CONFIG_LEDS_CLASS_FLASH=y
CONFIG_LEDS_TRIGGERS=y
CONFIG_LEDS_TRIGGER_TIMER=y
CONFIG_LEDS_TRIGGER_HEARTBEAT=y
CONFIG_LEDS_TRIGGER_DEFAULT_ON=y
CONFIG_LEDS_TRIGGER_PATTERN=y

# ── Power Supply / Battery ───────────────────────────────────
CONFIG_POWER_SUPPLY=y
CONFIG_POWER_SUPPLY_HWMON=y
CONFIG_BATTERY_BQ27XXX=m
CONFIG_CHARGER_BQ25890=m

# ── Wireless ─────────────────────────────────────────────────
CONFIG_RFKILL=y
CONFIG_RFKILL_INPUT=y
CONFIG_CFG80211=m
CONFIG_MAC80211=m
CONFIG_WIRELESS=y
CONFIG_WEXT_CORE=y
CONFIG_WEXT_PROC=y

# ── Bluetooth ────────────────────────────────────────────────
CONFIG_BT=m
CONFIG_BT_RFCOMM=m
CONFIG_BT_HIDP=m
CONFIG_BT_HCIBTUSB=m

# ── USB (for peripherals) ────────────────────────────────────
CONFIG_USB=y
CONFIG_USB_SUPPORT=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_EHCI_HCD=y
CONFIG_USB_STORAGE=y
CONFIG_USB_GADGET=y
CONFIG_USB_CONFIGFS=m

# ── Regulators (voltage/power rails) ─────────────────────────
CONFIG_REGULATOR=y
CONFIG_REGULATOR_FIXED_VOLTAGE=y

# ── RTC (Real Time Clock) ────────────────────────────────────
CONFIG_RTC_CLASS=y
CONFIG_RTC_DRV_PL031=y

# ── Thermal / CPU freq ───────────────────────────────────────
CONFIG_THERMAL=y
CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_DEFAULT_GOV_SCHEDUTIL=y
CONFIG_CPU_FREQ_GOV_PERFORMANCE=y
CONFIG_CPU_FREQ_GOV_POWERSAVE=y
CONFIG_CPU_FREQ_GOV_ONDEMAND=y
CONFIG_CPU_FREQ_GOV_CONSERVATIVE=y

# ── Watchdog ─────────────────────────────────────────────────
CONFIG_WATCHDOG=y

# ── IIO (Industrial I/O for sensors) ─────────────────────────
CONFIG_IIO=y
CONFIG_IIO_BUFFER=y
CONFIG_IIO_TRIGGERED_BUFFER=y
# Accelerometer / Gyro / Magnetometer
CONFIG_IIO_ST_ACCEL_3AXIS=m
CONFIG_IIO_ST_GYRO_3AXIS=m
CONFIG_IIO_ST_MAGN_3AXIS=m
CONFIG_IIO_ST_LSM6DSX=m
CONFIG_IIO_ST_PRESS=m
# Light / Proximity
CONFIG_VCNL4000=m
CONFIG_APDS9960=m
CONFIG_BH1750=m
