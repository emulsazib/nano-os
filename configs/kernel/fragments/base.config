# NanoOS Kernel Base Configuration Fragment

# DRM / Graphics
CONFIG_DRM=y
CONFIG_DRM_VIRTIO_GPU=y

# Input
CONFIG_INPUT_TOUCHSCREEN=y
CONFIG_INPUT_EVDEV=y
CONFIG_HID=y

# VirtIO
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_MMIO=y
CONFIG_DRM_VIRTIO_GPU=y

# Filesystems
CONFIG_EXT4_FS=y
CONFIG_TMPFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# Cgroups (systemd requirements)
CONFIG_CGROUPS=y
CONFIG_CGROUP_SCHED=y
CONFIG_CGROUP_PIDS=y
CONFIG_CGROUP_BPF=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_CGROUP_PERF=y
CONFIG_MEMCG=y

# Namespaces
CONFIG_NAMESPACES=y
CONFIG_USER_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y

# Filesystem notifications
CONFIG_INOTIFY_USER=y

# System calls needed by systemd
CONFIG_SIGNALFD=y
CONFIG_TIMERFD=y
CONFIG_EPOLL=y
CONFIG_FHANDLE=y

# DMI
CONFIG_DMIID=y

# Networking
CONFIG_NET=y
CONFIG_INET=y

# AutoFS (systemd requirement)
CONFIG_AUTOFS_FS=y

# TMPFS extended attributes
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_TMPFS_XATTR=y
